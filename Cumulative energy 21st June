% Graph: Cumulative energy
figure;
plot(hours_oslo,      Ecum_oslo,      'o-', 'LineWidth', 2, 'MarkerSize', 7); hold on;
plot(hours_furnace,   Ecum_furnace,   's-', 'LineWidth', 2, 'MarkerSize', 7);
plot(hours_pontianak, Ecum_pontianak, '^-', 'LineWidth', 2, 'MarkerSize', 7);
grid on;
xlabel('Hour of day');
ylabel('Cumulative energy (Wh)');
title('SP150 Cumulative Energy Over Time - 21st June');
legend('Oslo','Furnace Creek','Pontianak','Location','best');
xlim([0 23]);
ylim([0 max([Ecum_oslo; Ecum_furnace; Ecum_pontianak])*1.1]);
