%% 21st June: cumulative energy for Oslo, Furnace Creek, and Pontianak

modelName = "SP150";

filename_oslo      = "oslo 21st jun AVERAGE.xlsx";
filename_furnace   = "Furnace Creek 21st june AVERAGE.xlsx";
filename_pontianak = "pontianak 21st jun AVERAGE.xlsx";


% Fixed panel setting

Ns = 72;
assignin('base','Ns',Ns);
assignin('base','Rsh',1e7);
assignin('base','Eg0',1.12);


% NOCT model

NOCT_C = 45;

% Oslo

M = readmatrix(filename_oslo);

G_day_oslo    = M(:,end-1);
Tamb_day_oslo = M(:,end);

ok = isfinite(G_day_oslo) & isfinite(Tamb_day_oslo);
G_day_oslo    = G_day_oslo(ok);
Tamb_day_oslo = Tamb_day_oslo(ok);

n_oslo = min(length(G_day_oslo),24);
G_day_oslo    = G_day_oslo(1:n_oslo);
Tamb_day_oslo = Tamb_day_oslo(1:n_oslo);
hours_oslo    = (0:n_oslo-1)';

Tcell_C_oslo = Tamb_day_oslo + ((NOCT_C - 20)/800) .* G_day_oslo;

Pmpp_day_oslo = zeros(n_oslo,1);

for k = 1:n_oslo

    G   = G_day_oslo(k);
    T_C = Tcell_C_oslo(k);

    if G <= 1e-6
        Pmpp_day_oslo(k) = 0;
        continue
    end

    assignin('base','G',G);
    assignin('base','T',T_C + 273.15);

    try
        simOut = sim(modelName,'SrcWorkspace','base');

        V = simOut.Vout;
        I = simOut.Iout;
        if isa(V,'timeseries'), V = V.Data; end
        if isa(I,'timeseries'), I = I.Data; end
        V = V(:);
        I = I(:);
        ok2 = isfinite(V) & isfinite(I);
        V = V(ok2);
        I = I(ok2);
        if isempty(V) || isempty(I)
            Pmpp_day_oslo(k) = 0;
            continue
        end
        P = V .* I;
        Pmpp_day_oslo(k) = max(P);
        if ~isfinite(Pmpp_day_oslo(k)) || Pmpp_day_oslo(k) < 0
            Pmpp_day_oslo(k) = 0;
        end
    catch ME
        fprintf('Oslo simulation failed at hour %d: %s\n', hours_oslo(k), ME.message);
        Pmpp_day_oslo(k) = 0;
    end
end
Ecum_oslo = zeros(n_oslo,1);
for k = 2:n_oslo
    dt = hours_oslo(k) - hours_oslo(k-1);
    Ecum_oslo(k) = Ecum_oslo(k-1) + 0.5 * (Pmpp_day_oslo(k-1) + Pmpp_day_oslo(k)) * dt;
end

